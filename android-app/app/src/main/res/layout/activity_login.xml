<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 Parent Login"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log in with your parent account to bind this device"
            android:textSize="16sp"
            android:textColor="#718096"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Device Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:padding="16dp"
            android:background="#F7FAFC"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 This Device"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A5568"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/deviceInfoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device Model"
                android:textSize="16sp"
                android:textColor="#2D3748"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/deviceIdText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device ID: ..."
                android:textSize="12sp"
                android:textColor="#A0AEC0"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Email Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parent Email Address"
            android:textSize="14sp"
            android:textColor="#4A5568"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>

        <!-- Password Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textColor="#4A5568"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:maxLines="1"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="24dp"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#4A5568"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:minHeight="20dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Login &amp; Bind Device"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="16dp"/>

        <!-- Info Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ By logging in, this device will be bound to your parent account. You'll be able to monitor this device from your web dashboard."
            android:textSize="13sp"
            android:textColor="#718096"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="#EDF2F7"
            android:layout_marginBottom="16dp"/>

        <!-- Don't have account link -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have a parent account? Create one at the web dashboard"
            android:textSize="14sp"
            android:textColor="#4299E1"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
