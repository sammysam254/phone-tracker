<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:padding="24dp">

    <!-- Lock Icon -->
    <ImageView
        android:id="@+id/lockIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:src="@drawable/ic_shield"
        android:tint="#ff6b6b" />

    <!-- Lock Message -->
    <TextView
        android:id="@+id/lockMessageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/lockIcon"
        android:layout_marginTop="32dp"
        android:text="Device Locked by Parent"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:gravity="center"
        android:textAlignment="center" />

    <!-- Instructions -->
    <TextView
        android:id="@+id/instructionsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/lockMessageText"
        android:layout_marginTop="16dp"
        android:text="Enter the unlock code provided by your parent to unlock this device"
        android:textSize="16sp"
        android:textColor="#cccccc"
        android:gravity="center"
        android:textAlignment="center" />

    <!-- Unlock Code Input Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/unlockCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/instructionsText"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#2a2a2a"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unlock Code"
                android:textSize="14sp"
                android:textColor="#999999"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/unlockCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter 6-digit code"
                android:textColorHint="#666666"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:inputType="number"
                android:maxLength="6"
                android:gravity="center"
                android:padding="16dp"
                android:background="@android:color/transparent"
                android:letterSpacing="0.3" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#444444"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/unlockButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unlock Device"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_success"
                android:padding="16dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Contact Parent Text -->
    <TextView
        android:id="@+id/contactText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/unlockCard"
        android:layout_marginTop="32dp"
        android:text="Contact your parent to get the unlock code"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:textAlignment="center" />

    <!-- Warning Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:text="⚠️ Attempting to bypass this lock may result in device restrictions"
        android:textSize="12sp"
        android:textColor="#ff6b6b"
        android:gravity="center"
        android:textAlignment="center" />

</RelativeLayout>
