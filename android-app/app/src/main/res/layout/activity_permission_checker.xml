<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:id="@+id/headerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Permissions Status"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:padding="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Review and grant all required permissions for full monitoring functionality"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <!-- Permissions List Container -->
        <LinearLayout
            android:id="@+id/permissionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/grantAllButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Missing Permissions"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_primary"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/finishButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All Set - Continue"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_success"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
