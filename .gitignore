# APK files (except web-dashboard downloads)
*.apk
*.aab
# Allow only release APK files in web-dashboard for downloads
!web-dashboard/apk/app-release.apk
!web-dashboard/apk/child-app-v1.3.0.apk
!web-dashboard/apk/child-app-v1.5.0.apk
!web-dashboard/parent-apk/app-release.apk
!web-dashboard/parent-apk/parent-app-v1.4.0.apk
!web-dashboard/parent-apk/parent-monitor-v1.3.1-qr.apk
# Exclude debug APKs from being committed
web-dashboard/apk/app-debug.apk
web-dashboard/parent-apk/app-debug.apk

